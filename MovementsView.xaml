<Page x:Class="Praktika3.MovementsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Пропускная система" 
      Background="White"
      FontFamily="Bahnschrift Light SemiCondensed">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Пропускная система" FontSize="22" FontWeight="Bold" Foreground="#0C4882" Margin="0,0,0,20"/>
        <Border Grid.Row="1" Background="#BBDCFA" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Для прохода приложите карту или введите номер вручную" FontSize="14" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Номер карты:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtCardNumber" Width="200" Height="35" VerticalContentAlignment="Center"/>
                    <Button x:Name="BtnFind" Content="Найти сотрудника" Width="140" Height="35" Margin="10,0" Background="#0C4882" Foreground="White" BorderThickness="0" Click="BtnFind_Click"/>
                </StackPanel>
                <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Сотрудник:" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock x:Name="tbEmployeeInfo" Text="(не выбран)" Foreground="Gray"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="BtnEnter" Content="Вход" Width="100" Height="40" Background="#0C4882" Foreground="White" BorderThickness="0" Click="BtnEnter_Click"/>
            <Button x:Name="BtnExit" Content="Выход" Width="100" Height="40" Margin="10,0" Background="#0C4882" Foreground="White" BorderThickness="0" Click="BtnExit_Click"/>
            <Button x:Name="BtnRefresh" Content="Обновить историю" Width="140" Height="40" Margin="10,0" Background="#666" Foreground="White" BorderThickness="0" Click="BtnRefresh_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="История проходов" FontSize="16" FontWeight="Bold" Margin="0,10,0,5" Foreground="#0C4882"/>
        <DataGrid x:Name="MovementsGrid" Grid.Row="4" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#BBDCFA">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="200"/>
                <DataGridTextColumn Header="Номер карты" Binding="{Binding Employee.AccessCardNumber}" Width="120"/>
                <DataGridTextColumn Header="Время" Binding="{Binding TimeStamp, StringFormat=dd.MM.yyyy HH:mm:ss}" Width="150"/>
                <DataGridTextColumn Header="Направление" Binding="{Binding Direction}" Width="80"/>
                <DataGridTextColumn Header="Местоположение" Binding="{Binding Location}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>