<Window x:Class="Praktika3.AddEmployeeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление сотрудника"
        Width="400" Height="577" WindowStartupLocation="CenterOwner"
        FontFamily="Bahnschrift Light SemiCondensed">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="ФИО:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbFullName" Grid.Row="1" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="2" Text="Дата рождения:" FontWeight="Bold" Margin="0,5"/>
        <DatePicker x:Name="dpBirthDate" Grid.Row="3" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="4" Text="Паспортные данные:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbPassport" Grid.Row="5" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="6" Text="Банковские реквизиты:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbBank" Grid.Row="7" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="8" Text="Состояние здоровья:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbHealth" Grid.Row="9" Text="Здоров" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="10" Text="Номер карты доступа:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbCard" Grid.Row="11" Margin="0,0,0,10" Height="30"/>
        <CheckBox x:Name="cbHasFamily" Grid.Row="12" Content="Наличие семьи" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,68,0,0">
            <Button x:Name="BtnOk" Content="OK" Width="80" Height="30" Margin="5" Background="#0C4882" Foreground="White"/>
            <Button x:Name="BtnCancel" Content="Отмена" Width="80" Height="30" Margin="5" Background="#666666" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>