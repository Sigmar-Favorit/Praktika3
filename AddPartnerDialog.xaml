<Window x:Class="Praktika3.AddPartnerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление партнера"
        Width="450" Height="716" WindowStartupLocation="CenterOwner"
        FontFamily="Bahnschrift Light SemiCondensed">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="103"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Тип партнера:" FontWeight="Bold" Margin="0,5,0,5"/>
        <ComboBox x:Name="cbType" Margin="0,24,0,10" Grid.RowSpan="2">
            <ComboBoxItem Content="ЗАО"/>
            <ComboBoxItem Content="ООО"/>
            <ComboBoxItem Content="ПАО"/>
            <ComboBoxItem Content="ОАО"/>
        </ComboBox>
        <TextBlock Grid.Row="2" Text="Наименование:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="tbName" Grid.Row="3" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="4" Text="Директор:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="tbDirector" Grid.Row="4" Margin="0,24,0,10" Grid.RowSpan="2"/>
        <TextBlock Grid.Row="6" Text="Телефон:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="tbPhone" Grid.Row="6" Margin="0,24,0,10" Grid.RowSpan="2"/>
        <TextBlock Grid.Row="8" Text="Email:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="tbEmail" Grid.Row="8" Margin="0,24,0,10" Grid.RowSpan="2"/>
        <TextBlock Grid.Row="10" Text="Адрес:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="tbAddress" Grid.Row="10" Margin="0,24,0,10" Grid.RowSpan="2"/>
        <TextBlock Grid.Row="12" Text="ИНН:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="tbINN" Grid.Row="12" Margin="0,24,0,10" Grid.RowSpan="2"/>
        <TextBlock Grid.Row="14" Text="Рейтинг (1-10):" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="tbRating" Grid.Row="15" Text="5" Margin="0,1,0,21"/>
        <StackPanel Grid.Row="16" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,52,0,0" Width="180">
            <Button x:Name="BtnOk" Content="OK" Width="80" Height="30" Margin="5" Background="#0C4882" Foreground="White"/>
            <Button x:Name="BtnCancel" Content="Отмена" Width="80" Height="30" Margin="5" Background="#666666" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>