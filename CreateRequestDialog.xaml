<Window x:Class="Praktika3.CreateRequestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая заявка"
        Width="500" Height="662" WindowStartupLocation="CenterOwner"
        FontFamily="Bahnschrift Light SemiCondensed">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Партнер:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="cbPartner" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="2" Text="Продукция:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="cbProduct" Grid.Row="3" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="4" Text="Количество:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbQuantity" Grid.Row="5" Text="1" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="6" Text="Дата производства:" FontWeight="Bold" Margin="0,5"/>
        <DatePicker x:Name="dpDate" Grid.Row="7" Margin="0,10,0,298"/>
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,109,0,0">
            <Button x:Name="BtnOk" Content="Создать" Width="100" Height="30" Margin="5" Background="#0C4882" Foreground="White"/>
            <Button x:Name="BtnCancel" Content="Отмена" Width="80" Height="30" Margin="5" Background="#666666" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>