<Window x:Class="Praktika3.AddMaterialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление материала"
        Width="500" Height="786"
        WindowStartupLocation="CenterOwner"
        FontFamily="Bahnschrift Light SemiCondensed"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Тип материала:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="cbMaterialType" Grid.Row="1" DisplayMemberPath="TypeName" SelectedValuePath="Id" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="2" Text="Наименование:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbName" Grid.Row="3" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="4" Text="Поставщик:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="cbSupplier" Grid.Row="5" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="6" Text="Количество в упаковке:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbQtyPerPackage" Grid.Row="7" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="8" Text="Единица измерения:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbUnit" Grid.Row="9" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="10" Text="Стоимость:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbCost" Grid.Row="11" Margin="0,0,0,10" Height="30"/>
        <TextBlock Grid.Row="12" Text="Начальное количество на складе:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbQuantityStock" Grid.Row="12" Margin="0,29,0,238"/>
        <TextBlock Grid.Row="12" Text="Минимальное количество:" FontWeight="Bold" Margin="0,135,0,-125"/>
        <TextBox x:Name="tbMinQuantity" Grid.Row="12" Margin="0,157,0,116"/>
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,271,0,0">
            <Button x:Name="BtnOk" Content="OK" Width="80" Height="30" Margin="5" Background="#0C4882" Foreground="White"/>
            <Button x:Name="BtnCancel" Content="Отмена" Width="80" Height="30" Margin="5" Background="#666666" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>