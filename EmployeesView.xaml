<Page x:Class="Praktika3.EmployeesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сотрудники" 
      Background="White"
      FontFamily="Bahnschrift Light SemiCondensed">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="365*"/>
            <ColumnDefinition Width="36*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Сотрудники" FontSize="22" FontWeight="Bold" Foreground="#0C4882" Margin="0,0,0,20" Grid.ColumnSpan="2"/>
        <StackPanel Orientation="Horizontal" Margin="0,46,0,15" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <Button x:Name="BtnRefresh" Content="Обновить" Width="100" Height="35" Background="#0C4882" Foreground="White" BorderThickness="0" Click="BtnRefresh_Click"/>
            <Button x:Name="BtnAdd" Content="Добавить" Width="100" Height="35" Margin="10,0" Background="#0C4882" Foreground="White" BorderThickness="0" Click="BtnAdd_Click"/>
        </StackPanel>
        <DataGrid x:Name="EmployeesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#BBDCFA" Grid.ColumnSpan="2" Margin="0,50,0,0" Grid.RowSpan="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Паспорт" Binding="{Binding PassportData}" Width="150"/>
                <DataGridTextColumn Header="Семья" Binding="{Binding HasFamily}" Width="80"/>
                <DataGridTextColumn Header="Здоровье" Binding="{Binding HealthStatus}" Width="150"/>
                <DataGridTextColumn Header="Карта доступа" Binding="{Binding AccessCardNumber}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>