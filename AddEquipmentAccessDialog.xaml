<Window x:Class="Praktika3.AddEquipmentAccessDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление доступа к оборудованию"
        Width="400" Height="511"
        WindowStartupLocation="CenterOwner"
        FontFamily="Bahnschrift Light SemiCondensed"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Сотрудник:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="cbEmployee" Grid.Row="1" DisplayMemberPath="FullName" SelectedValuePath="Id"  Margin="0,0,0,15" Height="30"/>
        <TextBlock Grid.Row="2" Text="Оборудование:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbEquipment" Grid.Row="3" Margin="0,0,0,15" Height="30"/>
        <TextBlock Grid.Row="4" Text="Мастер:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="tbMaster" Grid.Row="5" Margin="0,10,0,212"/>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,101,0,0">
            <Button x:Name="BtnOk" Content="OK" Width="80" Height="30" Margin="5" Background="#0C4882" Foreground="White"/>
            <Button x:Name="BtnCancel" Content="Отмена" Width="80" Height="30" Margin="5" Background="#666666" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>